#!/usr/bin/env python3
"""
detect_fans - Auto-detect all real fans across all MAX31790 boards.

Uses the hwmon sysfs interface (fan<N>_fault = 0 means fan is present).

Output (JSON to stdout):
{
    "transport": "hwmon",
    "boards": [1],
    "fans": [
        { "board": 1, "fan": 2, "name": "Board1_Fan2", "rpm": 6597 },
        ...
    ],
    "count": 2
}
"""

import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from fan_common import (
    FANS_PER_BOARD,
    probe_boards,
    is_fan_present,
    get_transport,
)


def detect_all_fans():
    """Scan every discovered board, every channel, return only real fans."""
    boards = probe_boards()   # { board_num: hwmon_path }
    fans = []

    for board_num, hwmon_path in sorted(boards.items()):
        for fan_num in range(1, FANS_PER_BOARD + 1):
            present, rpm = is_fan_present(hwmon_path, fan_num)
            if present:
                fans.append({
                    "board": board_num,
                    "fan": fan_num,
                    "name": f"Board{board_num}_Fan{fan_num}",
                    "rpm": rpm,
                })

    return sorted(boards.keys()), fans


def main():
    try:
        board_list, fans = detect_all_fans()
        output = {
            "transport": get_transport(),
            "boards": board_list,
            "fans": fans,
            "count": len(fans),
        }
        print(json.dumps(output, indent=4))
    except Exception as e:
        error = {"error_msg": str(e)}
        print(json.dumps(error, indent=4), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
