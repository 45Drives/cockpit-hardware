#!/usr/bin/env python3
"""
detect_fans - Auto-detect all real fans across all MAX31790 boards.

Boards are discovered by probing known I2C addresses.
Fans are detected by reading tach counts — empty channels (near-max tach
values) and sub-threshold RPM readings are filtered out automatically.

Output (JSON to stdout):
{
    "boards": [1],
    "fans": [
        { "board": 1, "fan": 1, "name": "Board1_Fan1", "rpm": 5100 },
        ...
    ],
    "count": 2
}
"""

import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from fan_common import (
    FANS_PER_BOARD,
    probe_boards,
    get_fan_registers,
    is_fan_present,
    get_transport,
)


def detect_all_fans():
    """Scan every discovered board, every channel, return only real fans."""
    boards = probe_boards()
    fans = []

    for board_num, dev_addr in sorted(boards.items()):
        for fan_num in range(1, FANS_PER_BOARD + 1):
            config_reg, tach_reg, _pwm_reg = get_fan_registers(fan_num)
            present, rpm = is_fan_present(dev_addr, config_reg, tach_reg)
            if present:
                fans.append({
                    "board": board_num,
                    "fan": fan_num,
                    "name": f"Board{board_num}_Fan{fan_num}",
                    "rpm": rpm,
                })

    return sorted(boards.keys()), fans


def main():
    try:
        board_list, fans = detect_all_fans()
        output = {
            "transport": get_transport(),
            "boards": board_list,
            "fans": fans,
            "count": len(fans),
        }
        print(json.dumps(output, indent=4))
    except Exception as e:
        error = {"error_msg": str(e)}
        print(json.dumps(error, indent=4), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
