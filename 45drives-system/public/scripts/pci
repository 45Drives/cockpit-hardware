    "ff00:16:00.0": "0000:17:00.0",  # PCIE1
    "ff00:16:02.0": "0000:1c:00.0",  # PCIE2
    "ff00:64:00.0": "0000:65:00.0",  # PCIE4
    "ff00:64:02.0": "0000:66:00.0",  # PCIE3
    "ff00:b2:00.0": "0000:b3:00.0",  # PCIE6
    "ff00:b2:02.0": "0000:b4:00.0"   # PCIE5
}

